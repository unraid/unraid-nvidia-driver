        <?php foreach ($gpu_rows as $gpu):
          $support = $gpu['kernel_module_support'] ?? 'unknown';
          $tag_class = 'nv-tag-' . str_replace(' ', '-', $support);
          $tag_text = $support === 'open-only' ? 'Open Source only' :
                     ($support === 'proprietary-only' ? 'Legacy (Proprietary only)' :
