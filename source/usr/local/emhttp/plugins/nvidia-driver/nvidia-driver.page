<script>
if (window.history.replaceState) {
  window.history.replaceState(null, null, window.location.href);
}

function changeVersion(form) {
  var pkg = form.drv_version.value;
  openBox("/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh&arg1=update_version&arg2=" + pkg, "Downloading Package", 600, 800, true);
}

function filterVersions() {
  var mt = document.getElementById('module_type').value;
  var sel = document.getElementById('drv_version');
  var allowed = mt === 'opensource' ? ['latest_nos'] : ['latest','latest_prb','latest_nfb','latest_beta'];

  sel.querySelectorAll('option').forEach(function(o) {
    var og = o.closest('optgroup');
    if (!og) return;
    if (og.getAttribute('data-group') === 'branch') {
      o.style.display = allowed.indexOf(o.value) !== -1 ? '' : 'none';
    } else if (og.getAttribute('data-group') === 'pin') {
      o.style.display = o.getAttribute('data-type') === mt ? '' : 'none';
    }
  });
  sel.querySelectorAll('optgroup').forEach(function(og) {
    var vis = false;
    og.querySelectorAll('option').forEach(function(o) { if (o.style.display !== 'none') vis = true; });
    og.style.display = vis ? '' : 'none';
  });
  var cur = sel.options[sel.selectedIndex];
  if (cur && cur.style.display === 'none') {
    for (var i = 0; i < sel.options.length; i++) {
      if (sel.options[i].style.display !== 'none') { sel.selectedIndex = i; break; }
    }
  }

  var w = document.getElementById('blackwell-warning');
  if (w) w.style.display = (mt === 'proprietary' && <?php echo $is_blackwell ? 'true' : 'false'; ?>) ? '' : 'none';
  updateAutoUpdate();
}

function updateAutoUpdate() {
  var v = document.getElementById('drv_version').value;
  var ok = ['latest','latest_prb','latest_nfb','latest_beta','latest_nos'].indexOf(v) !== -1;
  var s = document.querySelector('[name="updata_check_selected"]');
  var b = document.getElementById('auto-update-btn');
  var n = document.getElementById('auto-update-note');
  if (s) { s.disabled = !ok; if (b) b.disabled = !ok; }
  if (n) n.style.display = ok ? 'none' : '';
}

$(function() { filterVersions(); });
</script>

<div class="nv-layout">

  <!-- System Info -->
  <div class="nv-card nv-span">
    <h2>System Information</h2>
    <div class="nv-grid">
      <div><div class="nv-label">Driver Version</div><div class="nv-val"><?php echo $installed_v; ?></div></div>
      <div><div class="nv-label">Kernel Module</div><div class="nv-val"><?php echo $module_type_display; ?></div></div>
      <?php if (!empty($cuda_v)): ?>
      <div><div class="nv-label">CUDA Version</div><div class="nv-val"><?php echo $cuda_v; ?></div></div>
      <?php endif; ?>
      <?php if (!empty($gpu_arch)): ?>
      <div><div class="nv-label">GPU Architecture</div><div class="nv-val"><?php echo $gpu_arch; ?> (<?php echo $arch_name; ?>)</div></div>
      <?php endif; ?>
      <div><div class="nv-label">Kernel</div><div class="nv-val"><?php echo $kernel_v; ?></div></div>
      <?php if (!empty($gpu_entries)): ?>
      <div class="nv-grid-full"><div class="nv-label">Installed GPU(s)</div>
        <?php foreach ($gpu_entries as $gpu): ?>
        <div class="nv-val"><?php echo htmlspecialchars(trim($gpu)); ?></div>
        <?php endforeach; ?>
      </div>
      <?php endif; ?>
    </div>
    <?php if ($is_blackwell): ?>
    <div class="nv-warn"><b>Blackwell GPU detected (sm_<?php echo str_replace('.', '', $gpu_arch); ?>):</b> This GPU architecture requires Open Source kernel modules. Proprietary modules will not load.</div>
    <?php endif; ?>
  </div>

  <!-- Driver Selection -->
  <div class="nv-card">
    <h2>Driver Selection</h2>
    <form name="nvidia_driver_settings" method="POST">
      <div class="nv-form-row">
        <label for="module_type">Module Type</label>
        <select id="module_type" onchange="filterVersions()">
          <?php echo mk_option($is_opensource_selected ? 'opensource' : 'proprietary', 'opensource', 'Open Source Kernel Module'); ?>
          <?php echo mk_option($is_opensource_selected ? 'opensource' : 'proprietary', 'proprietary', 'Proprietary Kernel Module'); ?>
        </select>
      </div>
      <div id="blackwell-warning" class="nv-warn" style="display:none">Your GPU requires Open Source kernel modules. Proprietary modules will not load on Blackwell GPUs.</div>
      <div class="nv-form-row">
        <label for="drv_version">Version</label>
        <select name="drv_version" id="drv_version" onchange="updateAutoUpdate()">
          <optgroup label="Follow Branch (auto-update)" data-group="branch">
            <?php echo mk_option(trim($selected_v), 'latest', 'Latest — v'.$latest_v); ?>
            <?php if (!empty(trim($latest_prb_v))) echo mk_option(trim($selected_v), 'latest_prb', 'Production — v'.$latest_prb_v); ?>
            <?php if (!empty(trim($latest_nfb_v))) echo mk_option(trim($selected_v), 'latest_nfb', 'New Feature — v'.$latest_nfb_v); ?>
            <?php if (!empty(trim($latest_beta_v))) echo mk_option(trim($selected_v), 'latest_beta', 'Beta — v'.$latest_beta_v); ?>
            <?php if (!empty(trim($latest_nos_v))) echo mk_option(trim($selected_v), 'latest_nos', 'Open Source — v'.$latest_nos_v); ?>
          </optgroup>
          <optgroup label="Pin Specific Version (kernel <?php echo $kernel_v; ?>)" data-group="pin">
            <?php
            $sorted = $eachlines; krsort($sorted);
            foreach ($sorted as $line) {
              $ver = trim($line);
              if (!empty($ver)) echo mk_option(trim($selected_v), $ver, 'v'.$ver, 'data-type="proprietary"');
            }
            if (!empty($nvos_versions)) {
              $nvos_sorted = $nvos_versions; rsort($nvos_sorted, SORT_NATURAL);
              foreach ($nvos_sorted as $nv) {
                $ver = trim($nv);
                if (!empty($ver)) echo mk_option(trim($selected_v), $ver, 'v'.$ver, 'data-type="opensource"');
              }
            }
            ?>
          </optgroup>
        </select>
      </div>
      <div class="nv-form-row">
        <label></label>
        <input type="button" value="Update &amp; Download" onclick="changeVersion(this.form)">
      </div>
    </form>
    <details class="nv-branch">
      <summary><i class="fa fa-info-circle"></i> Branch descriptions</summary>
      <dl>
        <dt>Latest</dt><dd>Always downloads the latest driver version regardless of branch.</dd>
        <dt>Production</dt><dd>Long lifecycle, ISV certified, optimal stability. Recommended for production.</dd>
        <dt>New Feature</dt><dd>Short lived branch (1-2 releases) with new features between Production releases.</dd>
        <dt>Beta</dt><dd>Cutting-edge features. May contain issues. Not for production use.</dd>
        <dt>Open Source</dt><dd>Open Source kernel modules (MIT/GPL) + proprietary libraries. Turing and newer only. <b>Required for Blackwell GPUs.</b>
        <?php if (isset($unraid_version['version']) && version_compare($unraid_version['version'], '7.0.0-rc.1.1', '<')): ?>
        <br>For GeForce/Workstation: create <code>/boot/config/modprobe.d/nvidia.conf</code> with <code>options nvidia NVreg_OpenRmEnableUnsupportedGpus=1</code>
        <?php endif; ?>
        </dd>
      </dl>
    </details>
  </div>

  <!-- Auto-Update -->
  <div class="nv-card">
    <h2>Auto-Update Notification</h2>
    <form method="POST">
      <div class="nv-form-row">
        <label for="updata_check_selected">Check for updates</label>
        <select name="updata_check_selected">
          <?php echo mk_option($update_check, 'true', 'Enabled'); ?>
          <?php echo mk_option($update_check, 'false', 'Disabled'); ?>
        </select>
        <input type="submit" name="changeUPDcheck" value="Apply" id="auto-update-btn">
      </div>
    </form>
    <div id="auto-update-note" class="nv-warn" style="display:none">Auto-update is only available when following a branch.</div>
    <p class="nv-muted">Checks once daily (8-10am) for new versions on the selected branch. Downloads automatically and sends a notification. <b>Reboot required to install.</b></p>
  </div>

  <!-- Links -->
  <div class="nv-card nv-span nv-links">
    <span>
      <a href="https://forums.unraid.net/topic/98978-plugin-nvidia-driver/" target="_blank"><i class="fa fa-comments-o"></i> Unraid Forum</a>
      <a href="https://github.com/unraid/unraid-nvidia-driver" target="_blank"><i class="fa fa-github"></i> GitHub</a>
      <a href="https://www.nvidia.com/en-us/drivers/unix/" target="_blank"><i class="fa fa-external-link"></i> Nvidia Driver Archive</a>
    </span>
  </div>

</div>

